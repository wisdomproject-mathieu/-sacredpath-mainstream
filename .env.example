# RevenueCat iOS public SDK key (starts with appl_). Do NOT use the RevenueCat secret API key.
# Production and TestFlight builds must set VITE_REVENUECAT_IOS_API_KEY.
VITE_REVENUECAT_IOS_API_KEY=appl_YOUR_PUBLIC_REVENUECAT_IOS_SDK_KEY

# Supabase public client configuration.
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
# Supabase anon key is safe for client-side use. Do NOT use the service-role key here.
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
