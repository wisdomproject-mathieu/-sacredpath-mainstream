# RevenueCat iOS public SDK key (starts with appl_). Do NOT use the RevenueCat secret API key.
# Production and TestFlight builds must set VITE_REVENUECAT_IOS_API_KEY.
VITE_REVENUECAT_IOS_API_KEY=appl_YOUR_PUBLIC_REVENUECAT_IOS_SDK_KEY

# Supabase public client configuration.
# The TTS backend runs as a Supabase Edge Function — both vars are required for voice to work.
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
# Supabase anon key is safe for client-side use. Do NOT use the service-role key here.
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Sacred Voice / Gemini TTS ───────────────────────────────────────────────
# The Gemini API key is a SERVER-SIDE secret set via:
#   supabase secrets set GEMINI_API_KEY=your_key
# It is never exposed to the client. Get a free key at https://aistudio.google.com/apikey
#
# Optional client-side overrides (safe to set in .env.local):
VITE_ORACLE_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Valid Gemini voice names: Sulafat (calm/warm), Leda (soft), Charon (deep)
VITE_ORACLE_GEMINI_VOICE_NAME=Sulafat

# ─── ElevenLabs TTS (optional fallback) ──────────────────────────────────────
# Set these as Supabase secrets to enable ElevenLabs as a Gemini fallback:
#   supabase secrets set ELEVENLABS_API_KEY=your_key
#   supabase secrets set ELEVENLABS_VOICE_ID=your_voice_id
# Optional client-side override:
# VITE_ELEVENLABS_VOICE_ID=your_voice_id
